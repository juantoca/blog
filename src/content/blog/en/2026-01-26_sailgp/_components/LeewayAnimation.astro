---
import Boat from '../boat.svg'
---

<div
  class="leeway-animation-container my-8 rounded-xl border border-neutral-200 bg-blue-50/50 p-4 dark:border-neutral-800 dark:bg-blue-950/20"
  style="--sail-angle: -45deg; --wind-direction: 90deg;"
>
  <svg viewBox="0 0 800 400" class="h-auto w-full" style="overflow: visible;">
    <defs>
      <!-- Centerboard / Orza -->
      <path
        id="keel"
        d="M -2,0 L -2,40 C -2,45 2,45 2,40 L 2,0 Z"
        fill="#4b5563"></path>

      <!-- Wind Pattern specifically for this component to prevent ID collision -->
      <pattern
        id="leeway-wind-pattern"
        x="0"
        y="0"
        width="100"
        height="100"
        style="transform: rotate(var(--wind-direction, 0deg))"
        patternUnits="userSpaceOnUse"
      >
        <g
          stroke="#3b82f6"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="3"
        >
          <path d="M 25,75 L 25,25"></path>
          <path d="M 15,35 L 25,25 L 35,35" fill="none"></path>

          <path d="M 75,100 L 75,50"></path>
          <path d="M 65,60 L 75,50 L 85,60" fill="none"></path>
        </g>
        <!-- Unique animation attribute to ensure it works isolated -->
        <animate
          attributeName="y"
          from="0"
          to="-100"
          dur="1.5s"
          repeatCount="indefinite"></animate>
      </pattern>
    </defs>

    <!-- Wind Background -->
    <rect
      fill="url(#leeway-wind-pattern)"
      width="100%"
      height="100%"
      opacity="0.4"></rect>

    <!-- Labels -->
    <text
      x="250"
      y="380"
      text-anchor="middle"
      class="fill-current text-sm font-semibold"
      opacity="0.7">CON ORZA</text
    >
    <text
      x="550"
      y="380"
      text-anchor="middle"
      class="fill-current text-sm font-semibold"
      opacity="0.7">SIN ORZA</text
    >

    <!-- Expected paths -->
    <path
      d="M 250,320 L 250,80"
      stroke="currentColor"
      stroke-width="2"
      stroke-dasharray="5 5"
      opacity="0.2"
      fill="none"></path>
    <path
      d="M 550,320 L 550,80"
      stroke="currentColor"
      stroke-width="2"
      stroke-dasharray="5 5"
      opacity="0.2"
      fill="none"></path>
    <!-- Leeway path -->
    <path
      d="M 550,320 L 700,80"
      stroke="currentColor"
      stroke-width="2"
      stroke-dasharray="5 5"
      opacity="0.2"
      fill="none"></path>

    <!-- Wind vector arrow to explain leeway (abatimiento) -->
    <g class="wind-vector" transform="translate(180, 200)" opacity="0.7">
      <path d="M 0,0 L 50,0" stroke="#3b82f6" stroke-width="3"></path>
      <polygon points="50,-5 60,0 50,5" fill="#3b82f6"></polygon>
      <text x="30" y="-10" text-anchor="middle" font-size="12" fill="#3b82f6"
        >Viento</text
      >
    </g>

    <g class="wind-vector" transform="translate(480, 200)" opacity="0.7">
      <path d="M 0,0 L 50,0" stroke="#3b82f6" stroke-width="3"></path>
      <polygon points="50,-5 60,0 50,5" fill="#3b82f6"></polygon>
      <text x="30" y="-10" text-anchor="middle" font-size="12" fill="#3b82f6"
        >Viento</text
      >
    </g>

    <!-- Leeway Path Arrow (Abatimiento) -->
    <g class="leeway-gap" transform="translate(550, 80)" opacity="0.8">
      <path
        d="M 0,0 L 140,0"
        stroke="#ef4444"
        stroke-width="2"
        stroke-dasharray="4 4"></path>
      <polygon points="140,-5 150,0 140,5" fill="#ef4444"></polygon>
      <text
        x="75"
        y="-10"
        text-anchor="middle"
        font-size="14"
        fill="#ef4444"
        font-weight="bold">Abatimiento</text
      >
    </g>

    <!-- Boat WITH KEEL -->
    <g class="boat-with-keel leeway-boat">
      <g transform="translate(250, 320)">
        <use href="#keel" transform="translate(0, -20)" opacity="0.5"></use>
        <g transform="translate(-48, -48)">
          <Boat width="96" height="96" />
        </g>
      </g>
    </g>

    <!-- Boat WITHOUT KEEL -->
    <g class="boat-without-keel leeway-boat">
      <g transform="translate(550, 320)">
        <g transform="translate(-48, -48)">
          <Boat width="96" height="96" />
        </g>
      </g>
    </g>
  </svg>
</div>

<style>
  .boat-with-keel {
    animation: sail-forward 5s ease-in-out infinite;
  }

  .boat-without-keel {
    animation: sail-leeway 5s ease-in-out infinite;
  }

  @keyframes sail-forward {
    0% {
      transform: translateY(0);
      opacity: 0;
    }
    10% {
      opacity: 1;
    }
    15% {
      transform: translateY(0);
    }
    85% {
      transform: translateY(-240px);
      opacity: 1;
    }
    95% {
      transform: translateY(-240px);
      opacity: 0;
    }
    100% {
      transform: translateY(0);
      opacity: 0;
    }
  }

  @keyframes sail-leeway {
    0% {
      transform: translate(0, 0);
      opacity: 0;
    }
    10% {
      opacity: 1;
    }
    15% {
      transform: translate(0, 0);
    }
    85% {
      transform: translate(150px, -240px);
      opacity: 1;
    }
    95% {
      transform: translate(150px, -240px);
      opacity: 0;
    }
    100% {
      transform: translate(0, 0);
      opacity: 0;
    }
  }
</style>
