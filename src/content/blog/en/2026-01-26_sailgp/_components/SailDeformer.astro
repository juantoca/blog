<script>
  function updateSailShape() {
    const sails = document.querySelectorAll('#mast-sail')
    if (!sails.length) return

    sails.forEach((path) => {
      // Get computed style directly from the path or its closest styled parent
      const style = getComputedStyle(path)

      // Parse values (removing 'deg' if present)
      const windDirStr =
        style.getPropertyValue('--wind-direction').trim() || '90deg'
      const sailAngleStr =
        style.getPropertyValue('--sail-angle').trim() || '0deg'

      const windDir = parseFloat(windDirStr) || 0
      const sailAngle = parseFloat(sailAngleStr) || 0

      // Calculate relative angle (-180 to 180)
      let relativeAngle = (windDir - sailAngle) % 360
      if (relativeAngle < 0) relativeAngle += 360
      if (relativeAngle > 180) relativeAngle -= 360

      // Calculate bulge
      const maxBulge = 15 // Increased for visibility
      const bulge = Math.sin((relativeAngle * Math.PI) / 180) * maxBulge

      // Construct new path with Quadratic curves for the sides
      // Original: M 84.57,55 C 87,55 87,60 86.5,60 L 86,110 L 83.14,110 L 82.64,60 C 82.14,60 82.14,55 84.57,55 Z

      // Right side control point base x: (86.5 + 86) / 2 = 86.25
      // Left side control point base x: (83.14 + 82.64) / 2 = 82.89
      // Midpoint y: (60 + 110) / 2 = 85

      const rightControlX = 86.25 + bulge
      const leftControlX = 82.89 + bulge

      const newD = `M 84.57,55 C 87,55 87,60 86.5,60 Q ${rightControlX},85 86,110 L 83.14,110 Q ${leftControlX},85 82.64,60 C 82.14,60 82.14,55 84.57,55 Z`

      path.setAttribute('d', newD)
    })
  }

  // Setup observer
  function setupSailObserver() {
    const root = document.documentElement
    const observer = new MutationObserver((mutations) => {
      let shouldUpdate = false
      mutations.forEach((mutation) => {
        if (
          mutation.type === 'attributes' &&
          mutation.attributeName === 'style'
        ) {
          shouldUpdate = true
        }
      })
      if (shouldUpdate) {
        updateSailShape()
      }
    })

    observer.observe(root, { attributes: true })

    // Initial update
    updateSailShape()

    // Add listener for astro page load
    document.addEventListener('astro:page-load', () => {
      updateSailShape()
    })
  }

  // Run on load
  setupSailObserver()
  document.addEventListener('astro:page-load', setupSailObserver)
</script>
