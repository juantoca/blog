---

<div class="rotatable-svg-component my-8 flex flex-col items-center justify-center gap-6 rounded-lg border bg-card p-6 shadow-sm">
  <div class="origin-center transition-transform duration-75 ease-out">
    <slot/>
  </div>

  <div class="flex w-full max-w-sm items-center gap-4">
    <span class="w-12 text-right text-sm text-muted-foreground">0°</span>
    <input
      type="range"
      min="0"
      max="360"
      value="0"
      class="rotation-slider h-2 w-full cursor-pointer appearance-none rounded-full bg-secondary accent-primary"
      aria-label="Rotate image"
    />
    <span class="w-12 text-sm text-muted-foreground">360°</span>
  </div>
  <div class="text-sm font-medium text-foreground">
    Rotation: <span class="rotation-value">0</span>°
  </div>
</div>

<script>
  function setupRotatableSvgs() {
    const components = document.querySelectorAll('.rotatable-svg-component')

    components.forEach((component) => {
      // Check if already initialized to prevent double-binding
      if (component.hasAttribute('data-initialized')) return
      component.setAttribute('data-initialized', 'true')

      const slider = component.querySelector('.rotation-slider')
      const wrapper = component.querySelector('.svg-wrapper')
      const valueDisplay = component.querySelector('.rotation-value')

      if (slider && wrapper && valueDisplay) {
        slider.addEventListener('input', (e) => {
          const target = e.target as HTMLInputElement
          const rotation = target.value
          ;(wrapper as HTMLElement).style.transform = `rotate(${rotation}deg)`
          valueDisplay.textContent = rotation
        })
      }
    })
  }

  // Initial setup
  setupRotatableSvgs()

  // Re-run on View Transitions navigation
  document.addEventListener('astro:page-load', setupRotatableSvgs)
</script>
